# ============================================================================
# Harness configuration — TEMPLATE. This file is committed; do NOT put real
# keys or webhooks here. Copy it to .env.local (gitignored) and fill values.
#
# Load it when running a command:
#   node --env-file=tools/ai-orchestrator/.env.local commands/run.mjs ...
# or export the variables in your shell / CI.
# ============================================================================

# ── Agent execution (for AI-authored tasks) ─────────────────────────────────
# AI-authored task types (requirement / scan / solution / implementation /
# review) are delegated to a tool-capable coding agent. The reference adapter
# uses the Cursor SDK. Validation tasks run real commands and need none of this.
CURSOR_API_KEY=
# Optional model override for the agent adapter.
CURSOR_AGENT_MODEL=composer-2

# ── Chat-channel broadcast (outbound IM) ────────────────────────────────────
# Each handoff can post one bot message to a chat channel. Provider options:
#   console = print to terminal only (default, no setup)
#   slack   = Slack incoming webhook
#   webhook = generic JSON webhook (e.g. Feishu / DingTalk custom bot)
AI_ORCH_IM_PROVIDER=console

# Default / fallback bot. Roles without their own webhook use this one.
AI_ORCH_IM_WEBHOOK=
# Optional signing secret / required keyword, depending on your webhook's
# security settings (leave blank if not used).
AI_ORCH_IM_SECRET=
AI_ORCH_IM_KEYWORD=
# Set to 1 to fully mute (no print, no push) — useful in CI / batch runs.
AI_ORCH_IM_MUTE=

# ── Per-role bots (optional) ────────────────────────────────────────────────
# Give each role its own bot in the SAME channel so messages show distinct
# senders. Pattern per role (suffix = UPPERCASE role id):
#   AI_ORCH_IM_WEBHOOK_<ROLE>   = that role's webhook URL
#   AI_ORCH_IM_SECRET_<ROLE>    = signing secret  (if enabled)
#   AI_ORCH_IM_KEYWORD_<ROLE>   = required keyword (if enabled)
# Roles without a WEBHOOK_<ROLE> fall back to the default bot above.
AI_ORCH_IM_WEBHOOK_PRODUCT=
AI_ORCH_IM_WEBHOOK_LEAD_ORCHESTRATOR=
AI_ORCH_IM_WEBHOOK_ARCHITECTURE=
AI_ORCH_IM_WEBHOOK_UX=
AI_ORCH_IM_WEBHOOK_FRONTEND=
AI_ORCH_IM_WEBHOOK_QA=
AI_ORCH_IM_WEBHOOK_REVIEW=
AI_ORCH_IM_WEBHOOK_SYSTEM=
# Optional support roles: AI_ORCH_IM_WEBHOOK_INTEGRATION= / _BACKEND= / _DEVOPS=
